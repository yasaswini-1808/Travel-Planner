# Backend Environment Variables

# JWT Secret Key (change this to a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345

# Anthropic API Key (for AI itinerary generation)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Groq API Key (for chatbot)
GROQ_API_KEY=your-groq-api-key-here

# Server Port
PORT=3001

# Frontend URL (used in password reset link)
FRONTEND_URL=http://localhost:5173

# SMTP settings for sending forgot-password emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Travel Planner <your-email@gmail.com>
